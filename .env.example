# ============================================================
#  PublicaMED · variáveis de ambiente
#  Copie para ".env" e preencha. NUNCA commite o .env real.
# ============================================================

# ─── App (browser / Vite) ───────────────────────────────────
# Chaves PÚBLICAS — seguras para ir ao bundle do front.
# Supabase → Project Settings → API → Project URL / anon public
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=cole-aqui-a-anon-key

# ─── Import script (node / servidor) ────────────────────────
# A service_role IGNORA o RLS. NUNCA exponha no front nem commite.
# Supabase → Project Settings → API → service_role (secret)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole-aqui-a-service-role-key

# Caminho do .jsx original de onde o SEED é extraído (opcional).
# Padrão: ./publicamed_sistema.jsx na raiz do projeto.
# SEED_SOURCE=./publicamed_sistema.jsx
